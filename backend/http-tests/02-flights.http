@baseUrl = http://localhost:8080/api/v1



### [1] Create a flight
# @name createFlight
POST {{baseUrl}}/flights?creatorId=1
Content-Type: application/json

{
  "originCity": "Bogota",
  "destinationCity": "Medellin",
  "departureDate": "2026-08-15",
  "arrivalDate": "2026-08-15",
  "startTime": "07:30:00",
  "endTime": "08:30:00",
  "seatPrice": 150000.00,
  "maxCapacity": 120,
  "status": "scheduled"
}

###

### [2] Get a flight by ID
GET {{baseUrl}}/flights/1

###

### [3] Search flights by origin, destination, and departure date
GET {{baseUrl}}/flights?origin=Bogota&destination=Medellin&date=2026-08-15
